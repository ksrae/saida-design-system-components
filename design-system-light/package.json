{
  "name": "@dc/synergy",
  "version": "0.0.1",
  "description": "design system with stencil js",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./loader": {
      "types": "./dist/loader/index.d.ts",
      "import": "./dist/loader/index.js",
      "require": "./dist/loader/index.cjs.js"
    },
    "./synergy": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/synergy/synergy.esm.js"
    },
    "./components/*.js": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./components": {
      "types": "./dist/components/custom-elements.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "build:all": "stencil build --config stencil.prod.config.ts",
    "clear": "powershell -Command \"Remove-Item -Recurse -Force -ErrorAction SilentlyContinue dist, components, .stencil\"",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "build-storybook": "stencil build && storybook build",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook:docs": "stencil build && storybook build --docs",
    "storybook:docs": "stencil build && storybook dev --docs -p 6006"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^1.1.1",
    "@stencil/core": "^4.38.1",
    "@stencil/react-output-target": "^1.5.1",
    "@stencil/sass": "^3.2.2",
    "@stencil/storybook-plugin": "^0.4.2",
    "@stencil/vue-output-target": "^0.13.1",
    "@storybook/addon-docs": "^9.1.10",
    "@storybook/addon-links": "^9.1.10",
    "@storybook/addon-themes": "^9.1.10",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "puppeteer": "^24.3.0"
  },
  "license": "MIT"
}

{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "declaration": false,
    "experimentalDecorators": true,
    "types": ["jest"],
    "lib": [
      "dom",
      "es2022",
      "esnext"
    ],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2022",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "h.Fragment",
    "skipLibCheck": true
  },
  "include": [
    "src"
],
  "exclude": [
    "node_modules",
    "dist",
    "components",
    "loader",
    "www"
  ]
}
